# ==============================================================================
# PORTFOLIO ENVIRONMENT VARIABLES CONFIGURATION (.env.example)
# ==============================================================================
# Instructions: Copy this file to `.env.local` and fill in your actual values.
# NEVER commit `.env.local` or any actual secret keys to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. CLIENT-SIDE PUBLIC VARIABLES (Safe for browser exposure)
# Prefix: NEXT_PUBLIC_
# ------------------------------------------------------------------------------

# Public site URL (used for CORS, social sharing, and SEO metadata)
# Example: https://krishna-portfolio.vercel.app or http://localhost:3000
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Contact email displayed on the portfolio website
NEXT_PUBLIC_CONTACT_EMAIL="your-email@example.com"

# Public Social Profiles
NEXT_PUBLIC_GITHUB_URL="https://github.com/your-username"
NEXT_PUBLIC_LINKEDIN_URL="https://www.linkedin.com/in/your-profile"
NEXT_PUBLIC_INSTAGRAM_URL="https://www.instagram.com/your-profile"

# ------------------------------------------------------------------------------
# 2. SERVER-ONLY SECRETS (Never exposed to browser / client bundle)
# ------------------------------------------------------------------------------

# Upstash Redis Configuration for Distributed Rate Limiting (Vercel deployments)
# Create a serverless Redis database at https://upstash.com/
# If left unset, the application automatically falls back to an in-memory LRU cache
# Note: In-memory fallback is per-serverless instance and reset on cold start.
UPSTASH_REDIS_REST_URL="https://your-redis-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_upstash_redis_rest_token_placeholder"

# API Authentication Secret Token (for protected admin or verification routes)
# Generate a strong 32+ character random string (e.g., openssl rand -hex 32)
API_SECRET_TOKEN="your_super_secret_api_token_placeholder"

# ------------------------------------------------------------------------------
# 3. RATE LIMITING CONFIGURATION (Requests allowed per time window)
# ------------------------------------------------------------------------------

# Contact form submissions (requests allowed per minute per IP)
RATE_LIMIT_CONTACT_PER_MIN="5"

# Public API endpoints (requests allowed per minute per IP)
RATE_LIMIT_PUBLIC_PER_MIN="60"

# Authentication verification endpoints (requests allowed per 15 minutes per IP)
RATE_LIMIT_AUTH_PER_15MIN="5"

# ------------------------------------------------------------------------------
# 4. CORS SECURITY & ALLOWED ORIGINS
# ------------------------------------------------------------------------------

# Comma-separated list of allowed origins for cross-origin API requests
# Example: https://krishna-portfolio.vercel.app,http://localhost:3000
ALLOWED_ORIGIN="http://localhost:3000"
